{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "simulator": {
      "ios": {
        "simulator": true,
        "buildConfiguration": "Release"
      }
    },
    "preview": {
      "ios": {
        "buildConfiguration": "Release",
        "distribution": "internal",
        "image": "macos-sequoia-15.2-xcode-16.2"
      }
    },
    "development": {
      "ios": {
        "buildConfiguration": "Debug",
        "distribution": "internal",
        "image": "macos-sequoia-15.2-xcode-16.2"
      }
    }
  }
}
